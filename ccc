#!/usr/bin/env bash
# Claude Code Commander (ccc) for CCP 3.0
# 直接读取 profile .env 并启动 Claude Code

set -euo pipefail

CCP_DIR="${HOME}/.ccp"
CCP_PROFILES_DIR="${CCP_DIR}/profiles"
CCP_CURRENT_FILE="${CCP_DIR}/current"

usage() {
    cat << 'EOF'
Usage:
  ccc <profile> [claude-options]
  ccc env <profile> [claude-options]

Examples:
  ccc work                                     # Launch with 'work' profile
  ccc env work                                 # Same, with explicit 'env' subcommand
  ccc env work --resume abc123                 # Resume a session
  ccc personal --dangerously-skip-permissions  # With Claude options

Available commands:
  ccp add <name>     # Add new profile
  ccp list           # List all profiles
  ccp status         # Show current status
EOF
}

die() {
    echo "ccc error: $1" >&2
    exit 1
}

is_valid_env_key() {
    [[ "$1" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
}

atomic_write() {
    local target="$1"
    local target_dir
    local tmp

    target_dir="$(dirname "$target")"
    mkdir -p "$target_dir"
    tmp=$(mktemp "${target}.tmp.XXXXXX")
    cat > "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$target"
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

# Support: ccc env <profile> [args...] OR ccc <profile> [args...]
if [[ "$1" == "env" ]]; then
    shift
    if [[ $# -lt 1 ]]; then
        die "'env' requires a profile name"
    fi
fi

profile="$1"
shift || true
claude_args=("$@")
env_file="${CCP_PROFILES_DIR}/${profile}.env"

if [[ ! -f "$env_file" ]]; then
    die "profile '${profile}' does not exist"
fi

has_base_url=0
has_auth_token=0
env_pairs=()

while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "$line" ]] && continue
    [[ "$line" != *=* ]] && continue

    key="${line%%=*}"
    value="${line#*=}"

    if ! is_valid_env_key "$key"; then
        die "invalid variable name: ${key}"
    fi

    [[ "$key" == "ANTHROPIC_BASE_URL" ]] && has_base_url=1
    [[ "$key" == "ANTHROPIC_AUTH_TOKEN" ]] && has_auth_token=1
    env_pairs+=("${key}=${value}")
done < "$env_file"

if (( !has_base_url )); then
    die "missing required variable: ANTHROPIC_BASE_URL"
fi

if (( !has_auth_token )); then
    die "missing required variable: ANTHROPIC_AUTH_TOKEN"
fi

if ! command -v claude >/dev/null 2>&1; then
    die "'claude' CLI not found. Install: npm install -g @anthropic-ai/claude-code"
fi

echo "$profile" | atomic_write "$CCP_CURRENT_FILE"

if [[ ${#claude_args[@]} -eq 0 ]]; then
    exec env -u ANTHROPIC_API_KEY "${env_pairs[@]}" claude
else
    exec env -u ANTHROPIC_API_KEY "${env_pairs[@]}" claude "${claude_args[@]}"
fi
