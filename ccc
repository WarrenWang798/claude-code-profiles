#!/usr/bin/env bash
# Claude Code Commander (CCC)
# 使用独立 settings JSON profile 启动 Claude Code

set -euo pipefail

CCC_DIR="${CCC_DIR:-${HOME}/.ccc}"
CCC_PROFILES_DIR="${CCC_DIR}/profiles"
CCC_CURRENT_FILE="${CCC_DIR}/current"
CC_SWITCH_DB="${CC_SWITCH_DB:-${HOME}/.cc-switch/cc-switch.db}"

usage() {
    cat << 'EOF'
Usage:
  ccc <profile> [claude-options]
  ccc list
  ccc show <profile>
  ccc path <profile>
  ccc import-cc-switch [--current]

Examples:
  ccc work
  ccc work --resume abc123
  ccc list
  ccc show work
  ccc import-cc-switch
  ccc import-cc-switch --current

Profile location:
  ~/.ccc/profiles/<profile>.json
EOF
}

die() {
    echo "ccc error: $1" >&2
    exit 1
}

ensure_dirs() {
    mkdir -p "$CCC_PROFILES_DIR"
    chmod 700 "$CCC_DIR"
    chmod 700 "$CCC_PROFILES_DIR"
}

atomic_write() {
    local target="$1"
    local target_dir
    local tmp

    target_dir="$(dirname "$target")"
    mkdir -p "$target_dir"
    tmp=$(mktemp "${target}.tmp.XXXXXX")
    cat > "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$target"
}

profile_file_path() {
    local profile="$1"
    echo "${CCC_PROFILES_DIR}/${profile}.json"
}

profile_exists() {
    local profile="$1"
    [[ -f "$(profile_file_path "$profile")" ]]
}

is_valid_profile_name() {
    [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]]
}

sanitize_profile_name() {
    local raw="$1"
    local sanitized

    sanitized=$(printf '%s' "$raw" \
        | tr '[:upper:]' '[:lower:]' \
        | sed 's/[^a-z0-9._-]/-/g; s/-\{1,\}/-/g; s/^-//; s/-$//')

    if [[ -z "$sanitized" ]]; then
        sanitized="profile"
    fi

    printf '%s' "$sanitized"
}

unique_profile_name() {
    local base="$1"
    local candidate="$base"
    local index=2

    while [[ -e "$(profile_file_path "$candidate")" ]]; do
        candidate="${base}-${index}"
        index=$((index + 1))
    done

    printf '%s' "$candidate"
}

has_import_name_loss() {
    local stripped
    stripped=$(printf '%s' "$1" | sed "s/[A-Za-z0-9._[:space:]-]//g")
    [[ -n "$stripped" ]]
}

stable_import_profile_name() {
    local raw="$1"
    local base
    local candidate
    local index=2

    base="$(sanitize_profile_name "$raw")"

    if [[ ! -e "$(profile_file_path "$base")" ]]; then
        printf '%s' "$base"
        return
    fi

    # 含非 ASCII 或特殊字符的 provider 名可能被压缩成已有短名称。
    # 这种情况下保留历史 fallback 命名，并在重复导入时稳定覆盖同一个 fallback 文件。
    if has_import_name_loss "$raw"; then
        while true; do
            candidate="${base}-${index}"
            if [[ -e "$(profile_file_path "$candidate")" ]]; then
                printf '%s' "$candidate"
                return
            fi
            printf '%s' "$candidate"
            return
        done
    fi

    printf '%s' "$base"
}

format_json() {
    awk '
        function indent(level,    text, i) {
            text = ""
            for (i = 0; i < level; i++) {
                text = text "  "
            }
            return text
        }

        BEGIN {
            level = 0
            in_string = 0
            escape = 0
            out = ""
        }

        {
            for (i = 1; i <= length($0); i++) {
                ch = substr($0, i, 1)

                if (in_string) {
                    out = out ch
                    if (escape) {
                        escape = 0
                    } else if (ch == "\\") {
                        escape = 1
                    } else if (ch == "\"") {
                        in_string = 0
                    }
                    continue
                }

                if (ch ~ /[[:space:]]/) {
                    continue
                }

                if (ch == "\"") {
                    out = out ch
                    in_string = 1
                } else if (ch == "{" || ch == "[") {
                    print out ch
                    level++
                    out = indent(level)
                } else if (ch == "}" || ch == "]") {
                    if (out !~ /^[ ]*$/) {
                        print out
                    }
                    level--
                    out = indent(level) ch
                } else if (ch == ",") {
                    print out ch
                    out = indent(level)
                } else if (ch == ":") {
                    out = out ": "
                } else {
                    out = out ch
                }
            }
        }

        END {
            if (out !~ /^[ ]*$/) {
                print out
            }
        }
    '
}

validate_json_object() {
    local file="$1"

    awk '
        function skip_ws(pos,    ch) {
            while (pos <= len) {
                ch = substr(json, pos, 1)
                if (ch !~ /[[:space:]]/) {
                    break
                }
                pos++
            }
            return pos
        }

        BEGIN {
            json = ""
        }

        {
            json = json $0 ORS
        }

        END {
            len = length(json)
            start = skip_ws(1)
            finish = len
            while (finish > start && substr(json, finish, 1) ~ /[[:space:]]/) {
                finish--
            }

            if (start > len || substr(json, start, 1) != "{" || substr(json, finish, 1) != "}") {
                exit 1
            }
        }
    ' "$file"
}

cmd_list() {
    ensure_dirs

    local found=0
    local current=""
    local profile_file profile

    if [[ -f "$CCC_CURRENT_FILE" ]]; then
        current=$(cat "$CCC_CURRENT_FILE")
    fi

    echo "Available profiles:"
    for profile_file in "${CCC_PROFILES_DIR}"/*.json; do
        [[ -f "$profile_file" ]] || continue
        found=1
        profile=$(basename "$profile_file" .json)
        if [[ "$profile" == "$current" ]]; then
            echo "  * $profile"
        else
            echo "    $profile"
        fi
    done

    if (( !found )); then
        echo "  (none)"
    fi
}

cmd_path() {
    local profile="${1:-}"
    [[ -z "$profile" ]] && die "profile name required"

    if ! profile_exists "$profile"; then
        die "profile '${profile}' does not exist"
    fi

    profile_file_path "$profile"
}

cmd_show() {
    local profile="${1:-}"
    local profile_file

    [[ -z "$profile" ]] && die "profile name required"

    if ! profile_exists "$profile"; then
        die "profile '${profile}' does not exist"
    fi

    profile_file=$(profile_file_path "$profile")

    echo "Profile: $profile"
    echo "Path: $profile_file"
    echo "Size: $(wc -c < "$profile_file" | tr -d ' ') bytes"
}

import_cc_switch() {
    local current_only=0
    local query
    local row name config profile target
    local imported=0

    if [[ "${1:-}" == "--current" ]]; then
        current_only=1
    elif [[ $# -gt 0 ]]; then
        die "unknown import-cc-switch option: $1"
    fi

    command -v sqlite3 >/dev/null 2>&1 || die "sqlite3 not found; cannot read cc-switch database"
    [[ -f "$CC_SWITCH_DB" ]] || die "cc-switch database not found: $CC_SWITCH_DB"

    ensure_dirs

    if (( current_only )); then
        query="select name, settings_config from providers where app_type='claude' and is_current=1 limit 1;"
    else
        query="select name, settings_config from providers where app_type='claude' order by is_current desc, sort_index, name;"
    fi

    while IFS=$'\t' read -r name config || [[ -n "$name$config" ]]; do
        [[ -z "$name" || -z "$config" ]] && continue

        profile=$(stable_import_profile_name "$name")
        target=$(profile_file_path "$profile")
        printf '%s\n' "$config" | format_json | atomic_write "$target"

        if ! validate_json_object "$target"; then
            rm -f "$target"
            die "cc-switch provider '${name}' does not contain a valid settings JSON object"
        fi

        echo "Imported: $name -> $profile"
        imported=$((imported + 1))
    done < <(sqlite3 -separator $'\t' "$CC_SWITCH_DB" "$query")

    if (( imported == 0 )); then
        die "no Claude providers found in cc-switch database"
    fi
}

launch_profile() {
    local profile="$1"
    shift || true
    local claude_args=("$@")
    local profile_file

    if ! profile_exists "$profile"; then
        die "profile '${profile}' does not exist"
    fi

    profile_file=$(profile_file_path "$profile")
    validate_json_object "$profile_file" || die "invalid profile settings JSON: $profile_file"

    command -v claude >/dev/null 2>&1 || die "'claude' CLI not found. Install: npm install -g @anthropic-ai/claude-code"

    echo "$profile" | atomic_write "$CCC_CURRENT_FILE"

    if [[ ${#claude_args[@]} -eq 0 ]]; then
        exec env -u ANTHROPIC_API_KEY claude --setting-sources "" --settings "$profile_file"
    else
        exec env -u ANTHROPIC_API_KEY claude --setting-sources "" --settings "$profile_file" "${claude_args[@]}"
    fi
}

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        help|-h|--help)
            usage
            ;;
        list|ls)
            cmd_list
            ;;
        show)
            shift
            cmd_show "$@"
            ;;
        path)
            shift
            cmd_path "$@"
            ;;
        import-cc-switch)
            shift
            import_cc_switch "$@"
            ;;
        *)
            if ! is_valid_profile_name "$cmd"; then
                die "invalid profile name: ${cmd}"
            fi
            shift || true
            launch_profile "$cmd" "$@"
            ;;
    esac
}

main "$@"
